# Copia a .env y rellena con los datos de tu VPS (Postgres, Qdrant, n8n).

# --- IA (n8n / agentes en el VPS) ---
GEMINI_API_KEY=
N8N_URL=https://tu-vps:5678
QDRANT_URL=https://tu-vps:6333

# --- Backend (perfil postgres, apunta al VPS) ---
POSTGRES_URL=jdbc:postgresql://tu-vps:5432/eventos
POSTGRES_USER=eventos
POSTGRES_PASSWORD=eventos

# --- Seguridad ---
# Secreto JWT (base64). Genera uno propio en producción.
APP_JWT_SECRET=b3JxdWVzdGEtZXZlbnRvcy1jbG91ZC1zZWNyZXQta2V5LWNoYW5nZS1tZS1wbGVhc2U=

# Orígenes CORS permitidos por el backend
APP_CORS_ORIGINS=http://localhost:5173
